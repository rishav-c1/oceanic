    "@testing-library/react": "^16.1.0",
    "@types/node": "^20.17.12",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
