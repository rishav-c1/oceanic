{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm start --port 4313",
      "url": [
        "http://localhost:4313/",
        "http://localhost:4313/about",
        "http://localhost:4313/services",
        "http://localhost:4313/projects",
        "http://localhost:4313/projects/certificates",
        "http://localhost:4313/gallery",
        "http://localhost:4313/contact"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
